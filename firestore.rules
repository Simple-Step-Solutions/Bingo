rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email == "logan@simplestepsolutions.com" && request.auth.token.email_verified == true)
      );
    }

    function isChamber() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'chamber')
      );
    }

    function isBusiness() {
      return isAuthenticated() && (
        isChamber() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'business')
      );
    }

    // ===============================================================
    // Users
    // Users can read and update their own profile.
    // Chamber can list all users (needed for admin panel).
    // Only admins can change roles.
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isChamber());
      allow list: if isChamber();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        // User can update their own profile but cannot change their role --
        // EXCEPT during initial role selection (roleSelected: false -> true)
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          (resource.data.roleSelected == false && request.resource.data.roleSelected == true)
        )) ||
        // Admins can update anything including role
        isAdmin() ||
        // Chamber can update town and board (but not role or email) for admin overrides
        (isChamber() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email']))
      );
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Businesses
    // Any authenticated user can read (needed to build bingo boards).
    // Only chamber+ can write.
    // ===============================================================

    match /businesses/{businessId} {
      allow read: if isAuthenticated();
      allow write: if isChamber();
    }

    // ===============================================================
    // Towns
    // Any authenticated user can read.
    // Only chamber+ can write.
    // ===============================================================

    match /towns/{townId} {
      allow read: if isAuthenticated();
      allow write: if isChamber();
    }

    // ===============================================================
    // Settings
    // Any authenticated user can read (needed on every page load).
    // Chamber+ can write (game config, branding, raffle settings).
    // ===============================================================

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isChamber();
    }

    // ===============================================================
    // Completions
    // Players can read and create their own completions.
    // Chamber can read all (analytics).
    // Only admins can delete (reset operations).
    // ===============================================================

    match /completions/{completionId} {
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isChamber());
      allow list: if isAuthenticated() && (request.auth.uid != null || isChamber());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isChamber());
      allow update: if isAdmin();
      allow delete: if isChamber();
    }

    // ===============================================================
    // Raffle Entries
    // Players can read and create their own entries.
    // Chamber can read and delete all entries (management).
    // ===============================================================

    match /raffle_entries/{entryId} {
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isChamber());
      allow list: if isChamber() ||
        // Players can list their own entries (filtered by userId)
        (isAuthenticated() && request.auth.uid != null);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isChamber();
    }

    // ===============================================================
    // Winners
    // Any authenticated user can read (public celebration).
    // Chamber+ can write.
    // ===============================================================

    match /winners/{winnerId} {
      allow read: if isAuthenticated();
      allow write: if isChamber();
    }

    // ===============================================================
    // Activities
    // Players write their own activity events.
    // Chamber can read all (analytics).
    // No one deletes (append-only log).
    // ===============================================================

    match /activities/{activityId} {
      allow read: if isChamber();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // Notifications
    // Any authenticated user can read all notifications.
    // Chamber+ can create notifications.
    // Chamber+ can update (for read receipts on user-specific notifications).
    // ===============================================================

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isChamber();
      allow delete: if isChamber();
    }

    // ===============================================================
    // Audit Log
    // Chamber can read and create audit entries (append-only trail).
    // ===============================================================

    match /audit_log/{logId} {
      allow read: if isChamber();
      allow create: if isChamber();
    }

    // ===============================================================
    // Invites
    // Chamber can create and list invites.
    // Any authenticated user can read (to validate token on redemption).
    // Any authenticated user can update (to mark as used).
    // ===============================================================

    match /invites/{inviteId} {
      allow read, list: if isAuthenticated();
      allow create: if isChamber();
      allow update: if isAuthenticated();
    }
  }
}
